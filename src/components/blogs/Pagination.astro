---
import { PAGINATION } from "@/lib/config";
import { buildPaginationRange } from "@/lib/pagination-range";
import { getPageUrl } from "@/lib/pagination-urls";
import type { PaginationProps } from "@/types";

export interface Props extends PaginationProps {}

const { pagination, basePath } = Astro.props;
const { currentPage, totalPages, hasPrevious, hasNext, previousPage, nextPage } = pagination;

const items = buildPaginationRange({ currentPage, totalPages, siblings: PAGINATION.DELTA });
---

<nav class="flex items-center justify-center gap-1" aria-label="페이지네이션">
  {
    hasPrevious ? (
      <a
        href={getPageUrl(basePath, previousPage!)}
        rel="prev"
        aria-label="이전 페이지"
        class="page-btn"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m15 18-6-6 6-6" />
        </svg>
      </a>
    ) : (
      <span aria-hidden="true" class="page-btn is-disabled">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6" />
        </svg>
      </span>
    )
  }

  <ol class="flex items-center gap-1" role="list">
    {
      items.map((item) =>
        item.type === "ellipsis" ? (
          <li aria-hidden="true" class="page-ellipsis">
            …
          </li>
        ) : (
          <li>
            {item.page === currentPage ? (
              <span aria-current="page" class="page-btn is-active">
                {item.page}
              </span>
            ) : (
              <a
                href={getPageUrl(basePath, item.page)}
                aria-label={`${item.page}페이지로 이동`}
                class="page-btn"
              >
                {item.page}
              </a>
            )}
          </li>
        ),
      )
    }
  </ol>

  {
    hasNext ? (
      <a href={getPageUrl(basePath, nextPage!)} rel="next" aria-label="다음 페이지" class="page-btn">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m9 18 6-6-6-6" />
        </svg>
      </a>
    ) : (
      <span aria-hidden="true" class="page-btn is-disabled">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m9 18 6-6-6-6" />
        </svg>
      </span>
    )
  }
</nav>

<style>
  .page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    color: var(--text-second);
    background-color: transparent;
    border-radius: 10px;
    text-decoration: none;
    transition:
      color 150ms ease,
      background-color 150ms ease,
      transform 150ms ease;
  }

  a.page-btn:hover {
    color: var(--heading);
    background-color: color-mix(in oklch, var(--gray-100) 80%, transparent);
  }

  a.page-btn:active {
    transform: scale(0.96);
  }

  a.page-btn:focus-visible {
    outline: 2px solid var(--progress-bar-color);
    outline-offset: 2px;
  }

  .page-btn.is-active {
    color: var(--page-background);
    background-color: var(--heading);
    cursor: default;
  }

  .page-btn.is-disabled {
    color: var(--text-disabled);
    opacity: 0.4;
    cursor: not-allowed;
  }

  .page-ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 2.5rem;
    color: var(--text-disabled);
    font-size: 0.875rem;
    user-select: none;
  }

  @media (max-width: 640px) {
    .page-btn {
      min-width: 2.25rem;
      height: 2.25rem;
      padding: 0 0.375rem;
      border-radius: 8px;
    }
    .page-ellipsis {
      width: 1.25rem;
      height: 2.25rem;
    }
  }
</style>
