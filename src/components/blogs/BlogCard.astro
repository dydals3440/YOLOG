---
import type { BlogCardProps } from '@/types'

import CategoryBadge from './CategoryBadge.astro'
import PostMeta from './PostMeta.astro'
import ReadingTime from './ReadingTime.astro'

export interface Props extends BlogCardProps {}

const { post } = Astro.props
const { title, description, date, category } = post.data
---

<article>
  <div class="mb-3 flex items-center gap-3">
    <CategoryBadge category={category} />
    <ReadingTime content={post.body} />
  </div>

  <h2 class="mb-2 text-lg font-semibold leading-snug text-primary line-clamp-2 sm:text-base">
    {title}
  </h2>

  {description && (
    <p class="mb-4 text-sm leading-relaxed text-second line-clamp-2">
      {description}
    </p>
  )}

  <PostMeta date={date} showArrow={true} />
</article>
